# Nombre del stack en Swarm
STACK_NAME=cunqa

# Imagen de CUNQA a usar
CUNQA_IMAGE=cunqa:dev

# Si no se define, el script intentará autodetectarla.
#ADVERTISE_ADDR=192.168.1.10

# IP del servidor NFS (por defecto ${ADVERTISE_ADDR})
#NFS_SERVER=192.168.1.10
NFS_EXPORT_PATH=/
NFS_VERSION=4.2
NFS_DOCKER_VOLUME=cunqa_export
NFS_CONTAINER_NAME=cunqa-nfs

# Slurm / cluster
WORKER_REPLICAS=1   #set to system preferences
CPUS_PER_NODE=6
SLURM_CLUSTER_NAME=cunqa
SLURM_PARTITION_NAME=debug
# Lista explícita de nodos por si no funca
# COMPUTE_NODES="worker-1 worker-2"

# Jupyter, lo debe lanzar el host, los otros consumen el servicio. REDIRIGIR PUERTO!!!
JUPYTER_TOKEN=cunqa
JUPYTER_PORT=8888
